DATABASE_URL=postgresql+asyncpg://vandix:changeme@db:5432/vandix
SECRET_KEY=change-me-to-a-random-string
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── AI Provider ───────────────────────────────────────────────
# Any OpenAI-compatible API works. Set these 3-4 values:
#
#   OPENAI_API_KEY     - your API key
#   OPENAI_BASE_URL    - API endpoint (no trailing slash)
#   OPENAI_MODEL       - model for activity generation
#   OPENAI_VISION_MODEL - model for OCR (optional, defaults to OPENAI_MODEL)
#
# ─── Examples ──────────────────────────────────────────────────
#
# OpenAI:
#   OPENAI_API_KEY=sk-xxx
#   OPENAI_BASE_URL=https://api.openai.com/v1
#   OPENAI_MODEL=gpt-4o
#   OPENAI_VISION_MODEL=gpt-4o
#
# Groq (fast, free tier):
#   OPENAI_API_KEY=gsk_xxx
#   OPENAI_BASE_URL=https://api.groq.com/openai/v1
#   OPENAI_MODEL=llama-3.3-70b-versatile
#   OPENAI_VISION_MODEL=llama-3.2-90b-vision-preview
#
# Together AI:
#   OPENAI_API_KEY=xxx
#   OPENAI_BASE_URL=https://api.together.xyz/v1
#   OPENAI_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct-Turbo
#
# Ollama (local):
#   OPENAI_API_KEY=ollama
#   OPENAI_BASE_URL=http://localhost:11434/v1
#   OPENAI_MODEL=llama3.1
#   OPENAI_VISION_MODEL=llava
#
# LiteLLM (proxy to any provider):
#   OPENAI_API_KEY=sk-xxx
#   OPENAI_BASE_URL=http://localhost:4000
#   OPENAI_MODEL=gpt-4o

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
OPENAI_VISION_MODEL=

REDIS_URL=redis://redis:6379
UPLOAD_DIR=./uploads
ALLOWED_ORIGINS=http://localhost:3000
